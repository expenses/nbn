rule slang
    command = slangc $in -o $out -O3 -warnings-as-errors all -I shaders -Wno-40009  -experimental-feature
build shaders/compiled/egui.spv: slang shaders/egui.slang | shaders/shared/colour.slang shaders/shared/hdr10.slang
build shaders/compiled/compute_example.spv: slang shaders/examples/compute_example.slang
build shaders/compiled/rt_triangle.spv: slang shaders/examples/rt_triangle.slang | shaders/shared/colour.slang shaders/shared/util.slang shaders/shared/derivatives.slang shaders/fallback_bindings.slang
build shaders/compiled/triangle_hdr.spv: slang shaders/examples/triangle_hdr.slang | shaders/shared/colour.slang shaders/shared/hdr10.slang
build shaders/compiled/triangle.spv: slang shaders/examples/triangle.slang | shaders/shared/colour.slang
build shaders/compiled/jungle.spv: slang shaders/jungle/jungle.slang | shaders/jungle/structs.slang shaders/shared/prefix_sum.slang shaders/shared/util.slang shaders/shared/derivatives.slang shaders/shared/structs.slang shaders/shared/colour.slang shaders/fallback_bindings.slang shaders/shared/constants.slang shaders/shared/barycentrics.slang shaders/shared/culling.slang
